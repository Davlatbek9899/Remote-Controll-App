<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_white"
    android:padding="24dp"
    android:layout_marginHorizontal="24dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Parol o'rnatish"
            android:textColor="#1A1A2E" android:textSize="18sp" android:textStyle="bold"/>
        <ImageButton android:id="@+id/btnCloseDialog"
            android:layout_width="32dp" android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@drawable/input_light" android:padding="6dp"/>
    </LinearLayout>

    <TextView android:id="@+id/tvPasswordStatus"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Parol o'rnatilmagan" android:textColor="#F8A11B"
        android:textSize="13sp" android:layout_marginBottom="16dp"/>

    <FrameLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:layout_marginBottom="16dp">

        <EditText android:id="@+id/etDialogPassword"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:inputType="number" android:maxLength="4"
            android:background="@drawable/input_light"
            android:textColor="#00000000" android:cursorVisible="false"
            android:focusable="true" android:focusableInTouchMode="true"
            android:clickable="true" android:textSize="1sp"/>

        <LinearLayout android:id="@+id/llPasswordDisplay"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="horizontal" android:gravity="center"
            android:clickable="true" android:focusable="false">

            <TextView android:id="@+id/tvSlot0"
                android:layout_width="36dp" android:layout_height="52dp"
                android:layout_weight="0" android:gravity="center|bottom"
                android:paddingBottom="4dp"
                android:text="*" android:textColor="#1B8EF8"
                android:textSize="26sp" android:textStyle="bold"
                android:includeFontPadding="false"/>
            <TextView android:id="@+id/tvSlot1"
                android:layout_width="36dp" android:layout_height="52dp"
                android:layout_weight="0" android:gravity="center|bottom"
                android:paddingBottom="4dp"
                android:text="*" android:textColor="#1B8EF8"
                android:textSize="26sp" android:textStyle="bold"
                android:includeFontPadding="false"/>
            <TextView android:id="@+id/tvSlot2"
                android:layout_width="36dp" android:layout_height="52dp"
                android:layout_weight="0" android:gravity="center|bottom"
                android:paddingBottom="4dp"
                android:text="*" android:textColor="#1B8EF8"
                android:textSize="26sp" android:textStyle="bold"
                android:includeFontPadding="false"/>
            <TextView android:id="@+id/tvSlot3"
                android:layout_width="36dp" android:layout_height="52dp"
                android:layout_weight="0" android:gravity="center|bottom"
                android:paddingBottom="4dp"
                android:text="*" android:textColor="#1B8EF8"
                android:textSize="26sp" android:textStyle="bold"
                android:includeFontPadding="false"/>
        </LinearLayout>
    </FrameLayout>

    <Button android:id="@+id/btnSavePassword"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:text="SAQLASH" android:background="@drawable/btn_blue"
        android:textColor="#FFFFFF" android:textSize="14sp"
        android:layout_marginBottom="8dp" android:stateListAnimator="@null"/>

    <Button android:id="@+id/btnRemovePassword"
        android:layout_width="match_parent" android:layout_height="42dp"
        android:text="Parolni o'chirish" android:background="@drawable/input_light"
        android:textColor="#FF4B4B" android:textSize="13sp"
        android:stateListAnimator="@null"/>
</LinearLayout>
