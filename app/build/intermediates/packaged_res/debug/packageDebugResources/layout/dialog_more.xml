<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/card_white"
    android:padding="20dp" android:layout_marginHorizontal="16dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="20dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="⚙️  Ko'proq"
            android:textColor="#1A1A2E" android:textSize="18sp" android:textStyle="bold"/>
        <android.widget.ImageButton android:id="@+id/btnCloseMore"
            android:layout_width="32dp" android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@drawable/input_light" android:padding="6dp"/>
    </LinearLayout>

    <!-- Quvvat to'ldi -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="@drawable/card_green_light" android:padding="14dp"
        android:layout_marginBottom="10dp">

        <LinearLayout android:layout_width="40dp" android:layout_height="40dp"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔋" android:textSize="22sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Quvvat to'ldi SMS"
                android:textColor="#1A1A2E" android:textSize="14sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="100% bo'lganda SMS yuboradi"
                android:textColor="#888888" android:textSize="11sp"/>
        </LinearLayout>

        <Switch android:id="@+id/switchBatteryFull"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Quvvat kam -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="@drawable/card_red_light" android:padding="14dp"
        android:layout_marginBottom="20dp">

        <LinearLayout android:layout_width="40dp" android:layout_height="40dp"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🪫" android:textSize="22sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Quvvat kam SMS"
                android:textColor="#1A1A2E" android:textSize="14sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="19% ga tushganda SMS yuboradi"
                android:textColor="#888888" android:textSize="11sp"/>
        </LinearLayout>

        <Switch android:id="@+id/switchBatteryLow"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- SMS raqami -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="SMS yuborish sozlamalari"
        android:textColor="#888888" android:textSize="12sp"
        android:layout_marginBottom="10dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="10dp">
        <TextView android:id="@+id/tvMorePhone"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Raqam kiritilmagan"
            android:textColor="#1A1A2E" android:textSize="13sp"/>
        <Button android:id="@+id/btnMorePhone"
            android:layout_width="wrap_content" android:layout_height="34dp"
            android:text="Raqam" android:background="@drawable/btn_blue"
            android:textColor="#FFFFFF" android:textSize="11sp"
            android:paddingHorizontal="12dp" android:stateListAnimator="@null"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="SIM karta tanlash"
            android:textColor="#1A1A2E" android:textSize="13sp"/>
        <Button android:id="@+id/btnMoreSim"
            android:layout_width="wrap_content" android:layout_height="34dp"
            android:text="SIM" android:background="@drawable/card_blue_light"
            android:textColor="#1B8EF8" android:textSize="11sp"
            android:paddingHorizontal="12dp" android:stateListAnimator="@null"/>
    </LinearLayout>
</LinearLayout>
