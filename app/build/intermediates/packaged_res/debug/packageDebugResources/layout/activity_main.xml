<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- Scroll content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNav"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="44dp"
                android:paddingBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Remote Control"
                        android:textColor="#1A1A2E"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Settings tugmasi -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnPassword"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/card_white"
                        android:text="🔐"
                        android:textSize="16sp"
                        android:padding="0dp"
                        android:stateListAnimator="@null"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnBlock"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/card_white"
                        android:text="🚫"
                        android:textSize="16sp"
                        android:padding="0dp"
                        android:stateListAnimator="@null"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Power card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_white"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- Pulse ring -->
                    <View
                        android:id="@+id/viewPulseRing"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:background="@drawable/pulse_ring_green"
                        android:layout_gravity="center"
                        android:alpha="0"
                        android:scaleX="1"
                        android:scaleY="1"/>

                    <!-- Asosiy tugma — o'zi qimirlamaydi -->
                    <ImageButton
                        android:id="@+id/btnPower"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_power"
                        android:background="@drawable/power_btn_red"
                        android:padding="22dp"
                        android:scaleType="fitCenter"
                        android:stateListAnimator="@null"/>

                    <!-- Loading view -->
                    <com.example.remotecontrol.DotsLoadingView
                        android:id="@+id/progressPower"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:visibility="gone"
                        android:layout_gravity="center"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xizmat holati"
                        android:textColor="#888888"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvPowerStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="O'chiq"
                        android:textColor="#FF4B4B"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bosib yoqing"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnTest"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Test"
                    android:background="@drawable/btn_blue"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:paddingHorizontal="16dp"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <!-- Tezkor buyruqlar -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tezkor buyruqlar"
                android:textColor="#1A1A2E"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Row 1 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">

                <LinearLayout android:id="@+id/cardSleepTimer"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/card_blue_light"
                    android:padding="14dp" android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎵" android:textSize="22sp"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sleep Timer"
                        android:textColor="#888888" android:textSize="11sp"
                        android:layout_marginTop="4dp"/>
                    <TextView android:id="@+id/tvSleepStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sozlash"
                        android:textColor="#1B8EF8" android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/cardReminder"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/card_yellow_light"
                    android:padding="14dp" android:layout_marginStart="8dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅" android:textSize="22sp"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Eslatma"
                        android:textColor="#888888" android:textSize="11sp"
                        android:layout_marginTop="4dp"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tez orada"
                        android:textColor="#F8A11B" android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">

                <LinearLayout android:id="@+id/cardAppTimer"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/card_red_light"
                    android:padding="14dp" android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱️" android:textSize="22sp"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ilova taymeri"
                        android:textColor="#888888" android:textSize="11sp"
                        android:layout_marginTop="4dp"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tez orada"
                        android:textColor="#FF4B4B" android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/cardMore"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/card_green_light"
                    android:padding="14dp" android:layout_marginStart="8dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚙️" android:textSize="22sp"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ko'proq"
                        android:textColor="#888888" android:textSize="11sp"
                        android:layout_marginTop="4dp"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avtomatik SMS"
                        android:textColor="#2DC96B" android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- So'nggi buyruqlar -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="So'nggi buyruqlar"
                android:textColor="#1A1A2E"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/llRecentCommands"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_white"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvRecentEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hali buyruq kelmagan"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="16dp"/>

                <ListView
                    android:id="@+id/lvRecentCommands"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:divider="#F0F0F0"
                    android:dividerHeight="1dp"
                    android:visibility="gone"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="@drawable/nav_bar_bg"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/nav_item_selected">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠"
                android:textSize="20sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asosiy"
                android:textColor="#1B8EF8"
                android:textSize="10sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- History -->
        <LinearLayout
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📜"
                android:textSize="20sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tarix"
                android:textColor="#AAAAAA"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- Commands -->
        <LinearLayout
            android:id="@+id/navCommands"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋"
                android:textSize="20sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buyruqlar"
                android:textColor="#AAAAAA"
                android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>
</RelativeLayout>
